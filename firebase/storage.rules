rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read access to all (to view product images)
      allow read: if true;

      // Allow uploads only to authenticated users
      allow write: if request.auth != null && (
        request.resource.size < 5 * 1024 * 1024 // limit 5MB per file
      );
    }
  }
}
